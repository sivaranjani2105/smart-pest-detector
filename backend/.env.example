# Flask Configuration
PORT=5000
SECRET_KEY=change_this_to_a_secure_random_key_in_production

# Sensor Service Configuration
# Use 'simulated' for local computer running/testing
# Use 'hardware' for actual deployment on Raspberry Pi
SENSOR_MODE=simulated
BUZZER_PIN=18

# Alert Thresholds
PM25_ALERT_THRESHOLD=50.0
MQ135_ALERT_THRESHOLD=500.0

# YOLO Configuration
YOLO_MODEL_PATH=yolo11n.pt
YOLO_CONFIDENCE_THRESHOLD=0.4
# If true, injects simulated crop pests (e.g. locust, armyworm) when camera runs
SIMULATE_PESTS=true

# Ollama LLM Configuration
OLLAMA_ENABLED=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Session Storage
BACKEND_DATA_DIR=data
